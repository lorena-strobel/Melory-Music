<%# Header Section - Adaptado do Tema Start Bootstrap %>
<header class="py-5 bg-white">
  <div class="container px-5 pb-5">
    <div class="row gx-5 align-items-center">
      <div class="col-xxl-5">
        <div class="text-center text-xxl-start">
          <div class="badge bg-gradient-primary-to-secondary text-white mb-4">
            <div class="text-uppercase">Gestão &middot; Música &middot; Inventário</div>
          </div>
          <div text-align: center>
          <div class="fs-3 fw-light text-muted">Bem-vindo ao sistema</div>
          <h1 class="display-3 fw-bolder mb-5">
            <span class="text-gradient d-inline">Melory Music Inventory</span>
          </h1>
          <div class="d-grid gap-3 d-sm-flex justify-content-sm-center justify-content-xxl-start mb-3">
            <%= link_to "Visualizar dashboard", dashboard_path, class: "btn btn-primary btn-lg px-5 py-3 me-sm-3 fs-6 fw-bolder" %>
          </div>
          </div>
        </div>
      </div>
      
      <div class="col-xxl-7">
        <%# Aqui em vez dos pontos SVG, vamos colocar um resumo rápido em cards %>
        <div class="d-flex justify-content-center mt-5 mt-xxl-0">
          <div class="row g-3">
            <div class="col-6">
              <div class="card shadow-sm border-0 bg-light p-4 text-center">
                <i class="bi bi-music-note-beamed fs-1 text-primary"></i>
                <h2 class="fw-bold mt-2"><%= Item.count %></h2>
                <p class="text-muted small">Instrumentos</p>
              </div>
            </div>
            <div class="col-6">
              <div class="card shadow-sm border-0 bg-light p-4 text-center">
                <i class="bi bi-tags fs-1 text-secondary"></i>
                <h2 class="fw-bold mt-2"><%= Brand.count %></h2>
                <p class="text-muted small">Marcas</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<%# Seção de "Sobre o Sistema" ou Instruções Rápidas %>
<section class="bg-light py-5">
  <div class="container px-5 text-center">
    <h2 class="display-5 fw-bolder"><span class="text-gradient d-inline">Controle Total</span></h2>
    <p class="lead fw-light mb-4">Use o menu para navegar entre o cadastro de instrumentos e fornecedores.</p>
    <div class="d-flex justify-content-center fs-2 gap-4">
      <i class="bi bi-shield-check text-primary"></i>
      <i class="bi bi-graph-up-arrow text-primary"></i>
      <i class="bi bi-cloud-check text-primary"></i>
    </div>
  </div>
</section>