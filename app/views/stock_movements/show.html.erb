<div class="card shadow-sm mx-auto" style="max-width: 500px;">
  <div class="card-body p-4 text-center">
    
  <%= render @stock_movement %>

    <hr class="my-4">

    <div class="d-flex flex-wrap gap-2 justify-content-center align-items-center">
      
      <%= link_to edit_stock_movement_path(@stock_movement), class: "btn btn-sm btn-warning" do %>
        <i class="bi bi-pencil"></i> Editar esta movimentação
      <% end %>

      <%= link_to stock_movements_path, class: "btn btn-sm btn-secondary" do %>
        <i class="bi bi-arrow-left"></i> Voltar para estoque
      <% end %>
    </div> 
  </div> 
</div>