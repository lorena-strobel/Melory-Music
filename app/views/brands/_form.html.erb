<%= form_with(model: brand) do |form| %>
  <% if brand.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(brand.errors.count, "error") %> prohibited this brand from being saved:</h2>

      <ul>
        <% brand.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

<fieldset>
    <div class="mb-3">
     <%= form.label :name_brand, class: "form-label" %>
      <%= form.text_field :name_item, class: "form-control"%>
    </div>

    <div class="mt-3">
          <%= form.submit "Criar Marca", class: "btn btn-primary" %>
        </div>
  </fieldset>
<% end %>