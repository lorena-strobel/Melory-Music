<%= form_with(model: brand) do |form| %>
  <% if brand.errors.any? %>
  <div class="alert alert-danger shadow-sm border-start border-danger" role="alert">
    <div class="d-flex align-items-center mb-2">
      <i class="bi bi-exclamation-octagon-fill me-2 fs-4"></i>
      <h5 class="alert-heading mb-0 fw-bold">Erro!</h5>
    </div>
    <hr>
    <ul class="mb-0">
      <% brand.errors.each do |error| %>
        <li><%= error.message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<fieldset>
    <div class="mb-3">
     <%= form.label :name_brand, class: "form-label" %>
      <%= form.text_field :name_brand, class: "form-control"%>
    </div>

    <div class="mt-3">
          <%= form.submit "Criar Marca", class: "btn btn-primary" %>
        <%= link_to brands_path, class: "btn btn-secondary" do %>
          <i class="bi bi-arrow-left"></i> Voltar para marcas
        <% end %>
    </div>
  </fieldset>
<% end %>