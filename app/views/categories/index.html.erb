<p style="color: green"><%= notice %></p>

<% content_for :title, "Categories" %>

<div class="d-flex align-items-center justify-content-between mb-4">
  <h1 class="mb-0 fw-bold text-dark">Categorias</h1>
  <%= link_to new_category_path, class: "btn btn-success" do %>
    <i class="bi bi-plus-lg"></i> Adicionar nova categoria
  <% end %>
</div>

<div class="card mb-4 bg-light shadow-sm">
  <div class="card-body">
    <%= search_form_for @q, class: "row g-3 align-items-end" do |f| %>  
      <div class="col-md-4">
        <%= f.label :name_category_cont, "Pesquisar por nome de categoria", class: "form-label" %>
        <%= f.search_field :name_category_cont, class: "form-control" %>
      </div>

      <div class="col-md-4">
        <%= f.label :items_name_item_cont, "Categoria que possui o Item:", class: "form-label" %>
        <%= f.search_field :items_name_item_cont, class: "form-control", placeholder: "Ex: Guitarra" %>
      </div>

      <div class="col-md-4">
        <%= f.submit "Filtrar", class: "btn btn-primary w-100" %>
      </div>
    <% end %>
  </div>
</div> 

<table class="table">
  <thead class="thead-dark">
    <tr>
      <th scope="col"><%= Category.human_attribute_name(:name_category) %></th>
      <th scope="col"><%= Category.human_attribute_name(:quantity_category)%></th>
      <th scope="col">Ações</th>
    </tr>
  </thead>
  <tbody>
    <% @categories.each do |category| %>
      <tr>
        <td><%= category.name_category %></td>
        <td><%= category.items.count %></td>
        <td>
          <div class="btn-group" role="group">
            <%= link_to category, class: "btn btn-sm btn-info", title: "Ver" do %>
            <i class="bi bi-pencil"></i> Ver
          <% end %>
          </div>
          <div class="btn-group" role="group">
            <%= link_to edit_category_path(category), class: "btn btn-sm btn-warning", title: "Editar" do %>
            <i class="bi bi-pencil"></i> Editar
          <% end %>
          </div>
          </div>
          <%= link_to category, data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" }, class: "btn btn-sm btn-danger", title: "Excluir" do %>
            <i class="bi bi-trash"></i> Excluir
          <% end %>
        </tr>
    <% end %>
  </tbody>
</table>