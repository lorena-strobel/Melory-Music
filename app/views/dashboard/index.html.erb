<div class="container mt-4">
  <h1 class="mb-4 text-center">Dashboard Melory Music</h1>

  <%# Formulário de Teste de Conversão %>
  <div class="card mb-4 border-primary shadow-sm">
    <div class="card-body bg-light">
      <h5 class="card-title text-primary"><i class="bi bi-currency-exchange"></i> Testar Conversão de Inventário</h5>
      
      <%= form_with url: dashboard_path, method: :get, local: true, class: "row g-3 align-items-center" do |f| %>
        <div class="col-auto">
          <label class="fw-bold">Escolha a moeda:</label>
        </div>
        <div class="col-auto">
          <%= f.select :currency, [['Real (BRL)', 'BRL'], ['Dólar (USD)', 'USD'], ['Euro (EUR)', 'EUR'], ['Libra (GBP)', 'GBP']], 
              { selected: @currency }, { class: "form-select" } %>
        </div>
        <div class="col-auto">
          <%= f.submit "Converter Agora", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Cards Principais %>
  <div class="row g-4 text-center mb-4">
    
    <%# Card de Valor Convertido (Destaque) %>
    <div class="col-md-12 col-lg-6 mx-auto">
      <div class="card bg-dark text-white shadow h-100">
        <div class="card-body d-flex flex-column justify-content-center">
          <h6 class="card-title opacity-75">VALOR TOTAL EM <%= @currency %></h6>
          <h2 class="display-4 fw-bold">
            <% if @currency == 'BRL' %>
              <%= number_to_currency(@total_exibir, unit: "R$ ", separator: ",", delimiter: ".") %>
            <% else %>
              <%= @currency %> <%= number_with_precision(@total_exibir, precision: 2) %>
            <% end %>
          </h2>
          <% if @exchange_rate %>
            <p class="mb-0 text-info small">Cotação: 1 <%= @currency %> = R$ <%= @exchange_rate %></p>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# Cards de Estatísticas %>
  <div class="row g-4">
    <div class="col-md-6 col-lg-3">
      <div class="card bg-primary text-white shadow h-100">
        <div class="card-body">
          <h6 class="card-title text-uppercase opacity-75">Valor Total (BRL)</h6>
          <h2 class="display-6 fw-bold">
            <%= number_to_currency(@total_brl, unit: "R$ ", separator: ",", delimiter: ".") %>
          </h2>
          <small class="opacity-75">Preço base do inventário</small>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-3">
      <div class="card bg-success text-white shadow h-100">
        <div class="card-body">
          <h6 class="card-title text-uppercase opacity-75">Itens no Catálogo</h6>
          <h2 class="display-6 fw-bold"><%= @total_items %></h2>
          <%= link_to "Ver todos", items_path, class: "text-white text-decoration-none small" %>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-3">
      <div class="card bg-info text-white shadow h-100">
        <div class="card-body">
          <h6 class="card-title text-uppercase opacity-75">Categorias</h6>
          <h2 class="display-6 fw-bold"><%= @total_categories %></h2>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-3">
      <div class="card bg-warning text-dark shadow h-100">
        <div class="card-body">
          <h6 class="card-title text-uppercase opacity-75">Movimentações</h6>
          <h2 class="display-6 fw-bold"><%= @total_stock_movements %></h2>
          <%= link_to "Histórico", stock_movements_path, class: "text-dark text-decoration-none small" %>
        </div>
      </div>
    </div>
  </div>
</div>