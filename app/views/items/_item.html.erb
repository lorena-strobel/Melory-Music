<div id="<%= dom_id item %>">
  <h2 class="card-title text-primary mb-4 text-center">
    <%= item.name_item %>
  </h2>

  <div class="row g-3 text-start">
    <div class="col-6 border-bottom pb-2">
      <span class="text-muted small d-block"><%= Item.human_attribute_name(:quantity_item) %></span>
      <strong class="h5 <%= item.quantity_item.to_i > 0 ? 'text-success' : 'text-danger' %>">
        <%= item.quantity_item %> unidades
      </strong>
    </div>

    <div class="col-6 border-bottom pb-2 text-end">
      <span class="text-muted small d-block"><%= Item.human_attribute_name(:price_item) %></span>
      <strong><%= number_to_currency(item.price_item) %></strong>
    </div>

    <div class="col-6 border-bottom pb-2">
      <span class="text-muted small d-block"><%= Item.human_attribute_name(:condition) %></span>
      <span class="text-dark"><%= item.condition %></span>
    </div>

    <div class="col-6 border-bottom pb-2 text-end">
      <span class="text-muted small d-block"><%= Item.human_attribute_name(:category_id) %></span>
      <strong><%= item.category&.name_category %></strong>
    </div>

    <div class="col-12 pt-2">
      <span class="text-muted small d-block"><%= Item.human_attribute_name(:brand_id) %></span>
      <p class="mb-0 fw-bold text-secondary"><%= item.brand&.name_brand %></p>
    </div>
  </div>
</div>