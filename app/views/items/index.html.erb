<p style="color: green"><%= notice %></p>

<% content_for :title, "Items" %>

<div class="d-flex align-items-center justify-content-between mb-4">
  <h1 class="mb-0">Items</h1>
  <%= link_to new_item_path, class: "btn btn-success" do %>
    <i class="bi bi-plus-lg"></i> Adicionar novo item
  <% end %>
</div>

<table class="table">
  <thead class="thead-dark">
    <tr>
      <th scope="col"><%= Item.human_attribute_name(:name_item) %></th>
      <th scope="col"><%= Item.human_attribute_name(:quantity_item)%></th>
      <th scope="col"><%= Item.human_attribute_name(:price_item)%></th>
      <th scope="col"><%= Item.human_attribute_name(:category_id)%></th>
      <th scope="col"><%= Item.human_attribute_name(:brand_id)%></th>
      <th scope="col">Ações</th>
    </tr>
  </thead>
  <tbody>
    <% @items.each do |item| %>
      <tr>
        <td><%= item.name_item %></td>
        <td><%= item.quantity_item %></td>
        <td><%= number_to_currency(item.price_item)%></td>
        <td><%= item.category.name_category %></td>
        <td><%= item.brand.name_brand %></td>
        <td>
          <div class="btn-group" role="group">
            <%= link_to item, class: "btn btn-sm btn-info", title: "Ver" do %>
            <i class="bi bi-pencil"></i> Ver
          <% end %>
          </div>
          <div class="btn-group" role="group">
            <%= link_to edit_item_path(item), class: "btn btn-sm btn-warning", title: "Editar" do %>
            <i class="bi bi-pencil"></i> Editar
          <% end %>
          </div>
          </div>
          <%= link_to item, data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" }, class: "btn btn-sm btn-danger", title: "Excluir" do %>
            <i class="bi bi-trash"></i> Excluir
          <% end %>
        </tr>
    <% end %>
  </tbody>
</table>
